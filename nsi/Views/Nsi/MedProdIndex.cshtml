@model IEnumerable<nsi.Models.MedicalProducts>
@{
    ViewData["Title"] = "Медицинские изделия";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <h2 class="mb-0">Медицинские изделия</h2>
    <button class="btn btn-primary btn-sm" onclick="Import('MedProd')">Импорт</button>
    <button class="btn btn-outline-danger btn-sm" onclick="Clear('MedProd')">Очистить</button>
    <span id="status" class="text-muted small"></span>
</div>
<table class="table table-striped table-bordered table-sm">
    <thead class="table-dark">
        <tr>
            <th>Наименование</th>
            <th>Описание</th>
            <th>Код</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Label</td>
                <td>@item.Description</td>
                <td>@item.Code</td>
                <td>@item.Status</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">Записи отсутствуют</td></tr>
        }
    </tbody>
</table>
