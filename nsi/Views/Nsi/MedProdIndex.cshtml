@model IEnumerable<nsi.Models.MedicalProducts>
@{
    ViewData["Title"] = "Медицинские изделия";
}

<h2>Медицинские препараты</h2>
<table class="table table-striped table-bordered table-sm">
    <thead class="table-dark">
        <tr>
            <th>Наименование</th>
            <th>Описание</th>
            <th>Код</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Label</td>
                <td>@item.Description</td>
                <td>@item.Code</td>
                <td>@item.Status</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">Записи отсутствуют</td></tr>
        }
    </tbody>
</table>
